@code {
    [Parameter]
    public VentaModel? Venta { get; set; }

    [Parameter]
    public ConfiguracionEmpresaModel? Empresa { get; set; }

    private string ConvertirNumeroALetras(decimal numero)
    {
        // Implementación básica para convertir números a letras
        // En producción, usar una librería especializada
        if (numero == 0) return "CERO";
        
        string[] unidades = { "", "UNO", "DOS", "TRES", "CUATRO", "CINCO", "SEIS", "SIETE", "OCHO", "NUEVE" };
        string[] decenas = { "", "DIEZ", "VEINTE", "TREINTA", "CUARENTA", "CINCUENTA", "SESENTA", "SETENTA", "OCHENTA", "NOVENTA" };
        string[] centenas = { "", "CIEN", "DOSCIENTOS", "TRESCIENTOS", "CUATROCIENTOS", "QUINIENTOS", "SEISCIENTOS", "SETECIENTOS", "OCHOCIENTOS", "NOVECIENTOS" };
        
        int parteEntera = (int)numero;
        int parteDecimal = (int)((numero - parteEntera) * 100);
        
        string letras = "";
        
        if (parteEntera >= 1000)
        {
            int miles = parteEntera / 1000;
            letras += $"{miles} MIL ";
            parteEntera %= 1000;
        }
        
        if (parteEntera >= 100)
        {
            letras += centenas[parteEntera / 100] + " ";
            parteEntera %= 100;
        }
        
        if (parteEntera >= 20)
        {
            letras += decenas[parteEntera / 10] + " ";
            parteEntera %= 10;
        }
        
        if (parteEntera > 0)
        {
            letras += unidades[parteEntera] + " ";
        }
        
        return $"{letras.Trim()} Y {parteDecimal:D2}/100 SOLES";
    }

    // Método para imprimir el comprobante
    private async Task ImprimirComprobante()
    {
