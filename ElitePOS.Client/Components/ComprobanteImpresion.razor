        <div style="width: 25%;">
            @if (!string.IsNullOrEmpty(Empresa?.LogoUrl))
            {
                <img src="@Empresa.LogoUrl" alt="Logo Empresa" style="max-width: 120px; max-height: 60px;" />
            }
            else
            {
                <div style="width: 120px; height: 60px; background: #f0f0f0; border: 1px solid #ddd; display: flex; align-items: center; justify-content: center;">
                    <span style="font-size: 10px; color: #666;">LOGO</span>
