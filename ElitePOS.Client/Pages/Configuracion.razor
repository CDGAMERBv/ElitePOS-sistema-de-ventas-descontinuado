@page "/configuracion"
@using ElitePOS.Client.Components
@using ElitePOS.Client.Services
@using ElitePOS.Shared.Models
@using ElitePOS.Services
@using Microsoft.AspNetCore.Components.Forms
@using ClosedXML.Excel
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ISesionService SesionService
@inject IConfiguracionEmpresaService ConfiguracionService
@inject IInventarioService InventarioService
@inject IVentasService VentasService
@inject INotificationService NotificationService
@inject PuntoVentaStateService StateService
@inject IImportacionExcelService ImportacionService

<style>
    /* ═══════════════════════════════════════════════════════════ */
    /* 🏥 SURGICAL RECONSTRUCTION: ELITE PREMIUM v2.6            */
    /* High-Fidelity Square Cards & 6-Column Grid Optimization    */
    /* ═══════════════════════════════════════════════════════════ */
    .v-config-page { padding: 40px; background: #f8fafc; min-height: 100vh; }
    
    .v-header-section { margin-bottom: 40px; border-left: 6px solid #1e293b; padding-left: 24px; }
    .v-title-main { font-size: 32px; font-weight: 900; color: #0f172a; margin: 0; letter-spacing: -1px; }
    .v-subtitle-main { color: #64748b; font-size: 15px; font-weight: 500; margin-top: 4px; }

    /* Elite Grid - EXACT 6 columns as requested (col-lg-2 equivalent) */
    .v-config-row { display: flex; flex-wrap: wrap; margin: 0 -10px; }
    
    .v-config-col { 
        position: relative;
        width: 100%;
        padding: 0 10px;
        margin-bottom: 20px;
        flex: 0 0 16.666667%; /* Strict 6 columns */
        max-width: 16.666667%;
    }

    /* Responsive fallbacks */
    @@media (max-width: 1200px) { .v-config-col { flex: 0 0 25%; max-width: 25%; } }
    @@media (max-width: 992px) { .v-config-col { flex: 0 0 33.3333%; max-width: 33.3333%; } }
    @@media (max-width: 768px) { .v-config-col { flex: 0 0 50%; max-width: 50%; } }
    @@media (max-width: 480px) { .v-config-col { flex: 0 0 100%; max-width: 100%; } }

    /* The Surgical Card: Square, Shadow-sm, 20px Radius */
    .v-config-card { 
        background: #ffffff; 
        border-radius: 20px; 
        border: 1px solid rgba(226, 232, 240, 0.6);
        padding: 30px 15px; 
        display: flex; 
        flex-direction: column; 
        align-items: center; 
        justify-content: center;
        text-align: center;
        cursor: pointer; 
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        aspect-ratio: 1 / 1.1; /* Keeps them roughly square */
        min-height: 200px;
        box-shadow: 0 1px 3px 0 rgba(0,0,0,0.05);
    }
    .v-config-card:hover { 
        transform: translateY(-8px);
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.05);
        border-color: #3b82f6;
    }

    /* Icon Container: 70x70, Pastoral Backgrounds */
    .v-icon-container { 
        width: 65px; 
        height: 65px; 
        border-radius: 18px; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        margin-bottom: 18px;
        transition: all 0.3s ease;
    }
    .v-config-card:hover .v-icon-container { transform: scale(1.1) rotate(5deg); }
    .v-icon-img { width: 40px; height: 40px; object-fit: contain; }

    /* Text Hierarchy */
    .v-card-title { font-size: 15px; font-weight: 800; color: #1e293b; margin: 0 0 6px 0; }
    .v-card-desc { font-size: 11.5px; color: #94a3b8; line-height: 1.4; margin: 0; padding: 0 8px; }

    /* Modular Logic Section */
    .v-section-divider { height: 1px; background: #e2e8f0; margin: 32px 0; }
    .v-section-headline { font-size: 13px; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 24px; display: flex; align-items: center; gap: 15px; }
    .v-section-headline::after { content: ""; flex: 1; height: 1px; background: #f1f5f9; }

    .v-module-card { 
        background: white; 
        border-radius: 20px; 
        padding: 24px 32px; 
        display: flex; 
        justify-content: space-between; 
        align-items: center; 
        box-shadow: 0 1px 2px rgba(0,0,0,0.02);
        max-width: 1000px;
        border: 1px solid #f1f5f9;
        transition: all 0.2s;
    }
    .v-module-card:hover { border-color: #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); }

    /* Animations */
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slideIn { from { transform: translateY(-20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    @@keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.05); } 100% { transform: scale(1); } }
</style>

<div class="v-config-page">
    @if (_cargando)
    {
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 60vh;">
            <div style="width: 60px; height: 60px; border: 4px solid #f3f4f6; border-top-color: #3b82f6; border-radius: 50%; animation: spin 1s linear infinite;"></div>
            <p style="margin-top: 24px; color: #64748b; font-weight: 800; font-size: 16px;">Sincronizando Core v2.6...</p>
        </div>
    }
    else
    {
        <div class="v-header-section">
            <h1 class="v-title-main">Configuración</h1>
            <p class="v-subtitle-main">Personaliza y gestiona el núcleo operativo de ElitePOS</p>
        </div>

        <!-- 🏁 GRILLA OPTIMIZADA: 6 COLUMNAS -->
        <div class="v-config-row">
            <!-- MI EMPRESA -->
            <div class="v-config-col">
                <div class="v-config-card" @onclick='() => NavigationManager.NavigateTo("/empresa")'>
                    <div class="v-icon-container" style="background: #eff6ff;">
                        <img src="icons/config-empresa.png" class="v-icon-img" alt="Empresa" />
                    </div>
                    <h3 class="v-card-title">Empresa</h3>
                    <p class="v-card-desc">Datos fiscales, logo y razón social</p>
                </div>
            </div>

            <!-- STAFF / USUARIOS -->
            <div class="v-config-col">
                <div class="v-config-card" @onclick='() => NavigationManager.NavigateTo("/usuarios")'>
                    <div class="v-icon-container" style="background: #fff7ed;">
                        <img src="icons/config-usuarios.png" class="v-icon-img" alt="Usuarios" />
                    </div>
                    <h3 class="v-card-title">Usuarios</h3>
                    <p class="v-card-desc">Control de acceso y roles del equipo</p>
                </div>
            </div>

            <!-- ALMACENES -->
            <div class="v-config-col">
                <div class="v-config-card" @onclick='() => NavigationManager.NavigateTo("/almacenes")'>
                    <div class="v-icon-container" style="background: #f0fdf4;">
                        <img src="icons/config-almacen.png" class="v-icon-img" alt="Almacenes" />
                    </div>
                    <h3 class="v-card-title">Almacenes</h3>
                    <p class="v-card-desc">Configuración de locales y stock</p>
                </div>
            </div>

            <!-- SUNAT / SOL -->
            <div class="v-config-col">
                <div class="v-config-card" @onclick='() => NavigationManager.NavigateTo("/sunat")'>
                    <div class="v-icon-container" style="background: #fef2f2;">
                        <img src="icons/config-sunat.png" class="v-icon-img" alt="SUNAT" />
                    </div>
                    <h3 class="v-card-title">SUNAT / SOL</h3>
                    <p class="v-card-desc">Integración de facturación electrónica</p>
                </div>
            </div>

            <!-- IMPRESORAS -->
            <div class="v-config-col">
                <div class="v-config-card" @onclick='() => NavigationManager.NavigateTo("/impresion")'>
                    <div class="v-icon-container" style="background: #f8fafc;">
                        <img src="icons/config-print.png" class="v-icon-img" alt="Impresión" />
                    </div>
                    <h3 class="v-card-title">Impresión</h3>
                    <p class="v-card-desc">Formato de tickets y hardware</p>
                </div>
            </div>

            <!-- SUSCRIPCIÓN -->
            <div class="v-config-col">
                <div class="v-config-card" @onclick='() => NavigationManager.NavigateTo("/plan")'>
                    <div class="v-icon-container" style="background: #fffbeb;">
                        <img src="icons/config-plan.png" class="v-icon-img" alt="Suscripción" />
                    </div>
                    <h3 class="v-card-title">Suscripción</h3>
                    <p class="v-card-desc">Estado de tu plan corporativo</p>
                </div>
            </div>

            <!-- IMPORTAR EXCEL -->
            <div class="v-config-col">
                <div class="v-config-card" @onclick="AbrirModalImportacion">
                    <div class="v-icon-container" style="background: #ecfdf5;">
                        <img src="icons/File-icon-upload.png" class="v-icon-img" alt="Importar" />
                    </div>
                    <h3 class="v-card-title">Importar</h3>
                    <p class="v-card-desc">Carga masiva de productos (Excel)</p>
                </div>
            </div>

            <!-- BACKUP TOTAL -->
            <div class="v-config-col">
                <div class="v-config-card" @onclick="DescargarBackup">
                    <div class="v-icon-container" style="background: #f0f9ff;">
                        <img src="icons/copia-de-seguridad.png" class="v-icon-img" alt="Backup" />
                    </div>
                    <h3 class="v-card-title">Backup Total</h3>
                    <p class="v-card-desc">Descarga los datos maestros en Excel</p>
                </div>
            </div>
        </div>

        <div class="v-section-divider"></div>

        <!-- SECCIÓN: MÓDULOS OPERATIVOS -->
        <h5 class="v-section-headline">Módulos Operativos</h5>
        
        <div class="v-module-card">
            <div style="display: flex; align-items: center; gap: 24px;">
                <div style="width: 52px; height: 52px; border-radius: 14px; background: #dbeafe; color: #1e40af; display: flex; align-items: center; justify-content: center; font-size: 22px;">
                    <i class="bi bi-safe2"></i>
                </div>
                <div>
                    <h4 style="font-size: 17px; font-weight: 800; color: #1e293b; margin: 0;">Módulo de Caja Chica</h4>
                    <p style="font-size: 13px; color: #64748b; margin: 2px 0 0 0;">Control de arqueos y flujos internos de efectivo</p>
                </div>
            </div>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" role="switch" checked="@Config.moduloCajaChicaActivo" @onchange="ToggleCajaChica" 
                       style="width: 50px; height: 25px; cursor: pointer; transition: all 0.2s;">
            </div>
        </div>

        <!-- BOTÓN FLOTANTE DE SOPORTE -->
        <button @onclick='() => mostrarModalSoporte = true' 
                style="position: fixed; bottom: 40px; right: 40px; width: 64px; height: 64px; background: #1e293b; color: white; border: none; border-radius: 50%; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 1000; transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);">
            <img src="icons/interrogacion.png" alt="Ayuda" style="width: 30px; height: 30px;" />
        </button>
    }
</div>

<!-- COMPONENTES MODULARES -->
<ModalSoporte Visible="@mostrarModalSoporte" OnCerrar="@(() => mostrarModalSoporte = false)" />

<!-- MODAL IMPORTACIÓN EXCEL (DRAG & DROP) -->
@if (mostrarModalImportacion)
{
    <div style="position: fixed; inset: 0; background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(4px); z-index: 9999; display: flex; align-items: center; justify-content: center; animation: fadeIn 0.2s;" @onclick="CerrarModalImportacion">
        <div @onclick:stopPropagation style="background: white; border-radius: 24px; padding: 40px; max-width: 500px; width: 90%; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); animation: slideIn 0.3s; text-align: center;">
            <div style="width: 80px; height: 80px; background: #ecfdf5; border-radius: 50%; margin: 0 auto 24px; display: flex; align-items: center; justify-content: center;">
                <img src="icons/File-icon-upload.png" style="width: 40px;" />
            </div>
            <h2 style="font-size: 24px; font-weight: 800; color: #1e293b; margin: 0 0 8px 0;">Importar Productos</h2>
            <p style="font-size: 14px; color: #64748b; margin-bottom: 32px;">Sube tu archivo .xlsx para actualizar el inventario masivamente</p>

            @if (archivoExcel == null)
            {
                <div style="border: 2px dashed #e2e8f0; border-radius: 12px; padding: 40px 20px; transition: all 0.2s; cursor: pointer; background: #f8fafc;" 
                     onmouseover="this.style.borderColor='#3b82f6'; this.style.background='#eff6ff'" 
                     onmouseout="this.style.borderColor='#e2e8f0'; this.style.background='#f8fafc'"
                     @onclick='() => JSRuntime.InvokeVoidAsync("clickElement", "fileImport")'>
                    <i class="bi bi-cloud-upload" style="font-size: 32px; color: #94a3b8;"></i>
                    <p style="margin: 12px 0 0 0; font-size: 13px; font-weight: 600; color: #475569;">Arrastra archivo o haz clic aquí</p>
                    <InputFile id="fileImport" OnChange="OnArchivoSeleccionado" accept=".xlsx" style="display: none;" />
                </div>
            }
            else
            {
                <div style="background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 12px; padding: 16px; margin-bottom: 24px; display: flex; align-items: center; gap: 12px; text-align: left;">
                    <i class="bi bi-file-earmark-check-fill" style="font-size: 24px; color: #10b981;"></i>
                    <div style="flex: 1; overflow: hidden;">
                        <p style="margin: 0; font-size: 13px; font-weight: 700; color: #166534; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@archivoExcel.Name</p>
                        <p style="margin: 0; font-size: 11px; color: #15803d;">Tamaño: @((archivoExcel.Size / 1024.0).ToString("N1")) KB</p>
                    </div>
                </div>

                <div style="display: grid; gap: 12px;">
                    <button @onclick="() => IniciarImportacion(false)" class="btn btn-success py-2 w-100 font-weight-bold" style="border-radius: 10px;">MANTENER ACTUALES Y AÑADIR</button>
                    <button @onclick="() => IniciarImportacion(true)" class="btn btn-outline-danger py-2 w-100 font-weight-bold" style="border-radius: 10px;">LIMPIAR TODO E IMPORTAR</button>
                </div>
            }

            <button @onclick="CerrarModalImportacion" style="margin-top: 20px; background: none; border: none; font-size: 13px; font-weight: 700; color: #94a3b8; cursor: pointer;">Cancelar</button>
        </div>
    </div>
}

<!-- MODAL BACKUP -->
@if (MostrarModalBackup)
{
    <div style="position: fixed; inset: 0; background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(8px); z-index: 2000; display: flex; align-items: center; justify-content: center;">
        <div style="background: white; border-radius: 28px; padding: 48px; width: 90%; max-width: 440px; text-align: center; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); animation: zoomIn 0.3s;">
            <div style="width: 90px; height: 90px; border-radius: 50%; background: #eff6ff; display: flex; align-items: center; justify-content: center; margin: 0 auto 32px;">
                <img src="icons/copia-de-seguridad.png" style="width: 48px; animation: pulse 2s infinite;" />
            </div>
            <h3 style="font-size: 22px; font-weight: 900; color: #0f172a; margin-bottom: 8px;">@MensajeBackup</h3>
            <p style="font-size: 14px; color: #64748b; margin-bottom: 32px;">No cierres la pestaña mientras procesamos tu información maestra.</p>
            <div style="height: 12px; border-radius: 6px; background: #f1f5f9; overflow: hidden; position: relative;">
                <div style="width: @(ProgresoBackup)%; height: 100%; background: linear-gradient(90deg, #3b82f6 0%, #6366f1 100%); transition: width 0.4s ease; border-radius: 6px;"></div>
            </div>
            <p style="margin-top: 16px; font-size: 12px; font-weight: 800; color: #3b82f6;">@ProgresoBackup% COMPLETADO</p>
        </div>
    </div>
}

@code {
    private ConfiguracionEmpresaModel Config = new();
    private bool _cargando = true;
    private bool mostrarModalSoporte = false;
    private bool mostrarModalImportacion = false;
    private IBrowserFile? archivoExcel = null;

    private bool MostrarModalBackup = false;
    private int ProgresoBackup = 0;
    private string MensajeBackup = "";

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        try { Config = await ConfiguracionService.ObtenerConfiguracion() ?? new(); }
        finally { _cargando = false; }
    }

    private async Task ToggleCajaChica(ChangeEventArgs e)
    {
        Config.moduloCajaChicaActivo = (bool)e.Value!;
        var result = await ConfiguracionService.GuardarConfiguracion(Config);
        if (result) {
            await NotificationService.ShowSuccess("Configuración sincronizada ✨");
            StateService.InvokeStateChange();
        }
    }

    private void AbrirModalImportacion() { archivoExcel = null; mostrarModalImportacion = true; }
    private void CerrarModalImportacion() => mostrarModalImportacion = false;

    private void OnArchivoSeleccionado(InputFileChangeEventArgs e)
    {
        archivoExcel = e.File;
        StateHasChanged();
    }

    private async Task IniciarImportacion(bool limpiarActuales)
    {
        if (archivoExcel == null) return;
        try
        {
            var empId = SesionService.UsuarioActual?.EmpresaId ?? "demo-empresa";
            CerrarModalImportacion();
            await NotificationService.ShowInfo("Iniciando importación masiva...");

            if (limpiarActuales) {
                var actuals = await InventarioService.ObtenerProductos();
                foreach(var p in actuals) await InventarioService.EliminarProducto(p.id);
            }

            using var stream = archivoExcel.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var res = await ImportacionService.ImportarProductosDesdeExcel(stream, empId);

            if (res.Exito) await NotificationService.ShowSuccess($"Éxito: {res.ProductosImportados} productos importados.");
            else await NotificationService.ShowError("Error: " + res.Mensaje);
        }
        catch (Exception ex) { await NotificationService.ShowError("Explosión en importación: " + ex.Message); }
    }

    private async Task DescargarBackup()
    {
        try
        {
            MostrarModalBackup = true;
            ProgresoBackup = 10;
            MensajeBackup = "Analizando Núcleo de Datos...";
            StateHasChanged();
            await Task.Delay(400);

            using var workbook = new XLWorkbook();
            
            ProgresoBackup = 30;
            MensajeBackup = "Extrayendo Inventario...";
            StateHasChanged();
            var productos = (await InventarioService.ObtenerProductos()).ToList();
            var wsP = workbook.Worksheets.Add("Inventario");
            string[] headersP = { "Código", "Nombre", "Categoría", "Stock", "Precio Costo", "Precio Venta" };
            for(int i=0; i<headersP.Length; i++) wsP.Cell(1, i+1).Value = headersP[i];
            wsP.Range("A1:F1").Style.Font.Bold = true; wsP.Range("A1:F1").Style.Fill.BackgroundColor = XLColor.BabyBlue;
            for (int i = 0; i < productos.Count; i++) {
                wsP.Cell(i+2, 1).Value = productos[i].codigoBarras;
                wsP.Cell(i+2, 2).Value = productos[i].nombre;
                wsP.Cell(i+2, 3).Value = productos[i].categoria;
                wsP.Cell(i+2, 4).Value = productos[i].stock;
                wsP.Cell(i+2, 5).Value = productos[i].precioCosto;
                wsP.Cell(i+2, 6).Value = productos[i].precioVenta;
            }

            ProgresoBackup = 60;
            MensajeBackup = "Extrayendo Historial de Ventas...";
            StateHasChanged();
            var ventas = (await VentasService.ObtenerVentas()).ToList();
            var wsV = workbook.Worksheets.Add("Ventas");
            string[] headersV = { "Fecha", "Comprobante", "Cliente", "Total", "Estado" };
            for(int i=0; i<headersV.Length; i++) wsV.Cell(1, i+1).Value = headersV[i];
            wsV.Range("A1:E1").Style.Font.Bold = true; wsV.Range("A1:E1").Style.Fill.BackgroundColor = XLColor.PastelGreen;
            for (int i = 0; i < ventas.Count; i++) {
                wsV.Cell(i+2, 1).Value = ventas[i].fechaHora.ToString("dd/MM/yyyy HH:mm");
                wsV.Cell(i+2, 2).Value = ventas[i].numeroComprobante;
                wsV.Cell(i+2, 3).Value = ventas[i].cliente;
                wsV.Cell(i+2, 4).Value = ventas[i].total;
                wsV.Cell(i+2, 5).Value = ventas[i].anulada ? "ANULADA" : "ACTIVA";
            }

            ProgresoBackup = 90;
            MensajeBackup = "Empaquetando Archivo Maestro...";
            StateHasChanged();
            
            using var stream = new MemoryStream();
            workbook.SaveAs(stream);
            var base64 = Convert.ToBase64String(stream.ToArray());
            await JSRuntime.InvokeVoidAsync("saveAsFile", $"EliteBackup_{DateTime.Now:yyyyMMdd_HHmm}.xlsx", base64);
            
            ProgresoBackup = 100;
            await Task.Delay(500);
        }
        catch (Exception ex) { await NotificationService.ShowError("Falla en Backup: " + ex.Message); }
        finally { MostrarModalBackup = false; }
    }
}
