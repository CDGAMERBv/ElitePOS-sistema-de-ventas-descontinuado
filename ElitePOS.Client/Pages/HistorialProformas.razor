@page "/proformas"
@using ElitePOS.Shared.Models
@using ElitePOS.Client.Services
@using ElitePOS.Services
@inject IProformasService ProformasService
@inject IInventarioService InventarioService
@inject IConfiguracionEmpresaService ConfiguracionService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject GestionStateService StateService
@inject INotificationService NotificationService
@implements IDisposable

<div class="dashboard-premium px-4 py-6" style="padding: 24px;">
    <div style="margin-bottom: 24px;">
        <h3 style="font-weight: 800; font-size: 24px; margin: 0 0 8px 0; color: #111827;">Historial de Proformas</h3>
        <p style="margin: 0; color: #6B7280; font-size: 14px;">Gestión de cotizaciones y presupuestos previos a la venta</p>
    </div>

    <!-- Resumen -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 24px;">
        <div class="glass-card" style="padding: 20px;">
            <span style="color: #6B7280; font-size: 12px; font-weight: 600; text-transform: uppercase;">Proformas Activas</span>
            <h4 style="font-weight: 800; margin: 8px 0; font-size: 24px; color: #10B981;">@proformasFiltradas.Count(p => !p.anulada && p.estadoSunat != "CONVERTIDA")</h4>
        </div>
        <div class="glass-card" style="padding: 20px;">
            <span style="color: #6B7280; font-size: 12px; font-weight: 600; text-transform: uppercase;">Proformas Anuladas</span>
            <h4 style="font-weight: 800; margin: 8px 0; font-size: 24px; color: #EF4444;">@proformasFiltradas.Count(p => p.anulada)</h4>
        </div>
    </div>

    <!-- Filtros -->
    <div class="glass-card" style="padding: 20px; margin-bottom: 24px; display: flex; gap: 16px; flex-wrap: wrap; align-items: flex-end;">
        <div style="flex: 1; min-width: 250px;">
            <label style="display: block; font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px;">Búsqueda</label>
            <div style="position: relative;">
                <i class="bi bi-search" style="position: absolute; left: 12px; top: 12px; color: #94A3B8;"></i>
                <input type="text" @bind="textoBusqueda" @bind:event="oninput" @bind:after="FiltrarProformas" placeholder="Buscar por cliente o N° comprobante..." style="width: 100%; padding: 10px 10px 10px 36px; border: 1px solid #E2E8F0; border-radius: 8px; outline: none; transition: border-color 0.2s;" />
            </div>
        </div>
        <div>
            <label style="display: block; font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px;">Desde</label>
            <input type="date" @bind="fechaInicio" @bind:after="CargarProformas" style="padding: 9px; border: 1px solid #E2E8F0; border-radius: 8px; outline: none;" />
        </div>
        <div>
            <label style="display: block; font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px;">Hasta</label>
            <input type="date" @bind="fechaFin" @bind:after="CargarProformas" style="padding: 9px; border: 1px solid #E2E8F0; border-radius: 8px; outline: none;" />
        </div>
        <div>
            <label style="display: block; font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px;">Estado</label>
            <select @bind="estadoFiltro" @bind:after="FiltrarProformas" style="padding: 10px; border: 1px solid #E2E8F0; border-radius: 8px; outline: none; background: white;">
                <option value="">Todos los estados</option>
                <option value="pendiente">Activa</option>
                <option value="convertida">Convertida</option>
                <option value="anulada">Anulada</option>
            </select>
        </div>
    </div>

    <!-- Tabla -->
    <div class="glass-card" style="padding: 24px; overflow-x: auto;">
        <h5 style="font-weight: 700; margin: 0 0 16px 0; font-size: 16px; color: #111827;">Listado de Proformas</h5>

        @if (cargando)
        {
            <div style="text-align: center; padding: 40px 0;">
                <p style="color: #6B7280;">Recuperando proformas...</p>
            </div>
        }
        else if (proformasFiltradas == null || !proformasFiltradas.Any())
        {
            <div style="text-align: center; padding: 40px 0;">
                <i class="bi bi-file-earmark-text" style="font-size: 40px; color: #94A3B8; margin-bottom: 12px; display: block;"></i>
                <p style="color: #6B7280; font-weight: 500;">Sin coincidencias para los filtros aplicados</p>
            </div>
        }
        else
        {
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr>
                        <th style="text-align: left; font-weight: 600; color: #6B7280; font-size: 12px; padding-bottom: 12px; border-bottom: 1px solid #E2E8F0;">FECHA</th>
                        <th style="text-align: left; font-weight: 600; color: #6B7280; font-size: 12px; padding-bottom: 12px; border-bottom: 1px solid #E2E8F0;">COMPROBANTE</th>
                        <th style="text-align: left; font-weight: 600; color: #6B7280; font-size: 12px; padding-bottom: 12px; border-bottom: 1px solid #E2E8F0;">CLIENTE</th>
                        <th style="text-align: right; font-weight: 600; color: #6B7280; font-size: 12px; padding-bottom: 12px; border-bottom: 1px solid #E2E8F0;">TOTAL</th>
                        <th style="text-align: center; font-weight: 600; color: #6B7280; font-size: 12px; padding-bottom: 12px; border-bottom: 1px solid #E2E8F0;">ESTADO</th>
                        <th style="text-align: right; font-weight: 600; color: #6B7280; font-size: 12px; padding-bottom: 12px; border-bottom: 1px solid #E2E8F0;">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var proforma in proformasFiltradas.OrderByDescending(p => p.fechaHora))
                    {
                        <tr>
                            <td style="padding: 12px 0; border-bottom: 1px solid #F1F5F9; color: #6B7280; font-size: 13px;">@proforma.fechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                            <td style="padding: 12px 0; border-bottom: 1px solid #F1F5F9; font-weight: 600; color: #111827; font-size: 14px;">@proforma.numeroComprobante</td>
                            <td style="padding: 12px 0; border-bottom: 1px solid #F1F5F9; color: #475569; font-size: 14px;">@proforma.cliente</td>
                            <td style="text-align: right; padding: 12px 0; border-bottom: 1px solid #F1F5F9; font-weight: 700; font-size: 14px; color: #10B981;">
                                @simboloMoneda @proforma.total.ToString("N2")
                            </td>
                            <td style="text-align: center; padding: 12px 0; border-bottom: 1px solid #F1F5F9;">
                                @if (proforma.anulada)
                                {
                                    <span style="background: rgba(239,68,68,0.1); color: #EF4444; padding: 4px 10px; border-radius: 6px; font-weight: 700; font-size: 11px;">ANULADA</span>
                                }
                                else if (proforma.estadoSunat == "CONVERTIDA")
                                {
                                    <span style="background: rgba(16,185,129,0.1); color: #10B981; padding: 4px 10px; border-radius: 6px; font-weight: 700; font-size: 11px;">CONVERTIDA</span>
                                }
                                else
                                {
                                    <span style="background: rgba(245,158,11,0.1); color: #F59E0B; padding: 4px 10px; border-radius: 6px; font-weight: 700; font-size: 11px;">ACTIVA</span>
                                }
                            </td>
                            <td style="text-align: right; padding: 12px 0; border-bottom: 1px solid #F1F5F9;">
                                <div style="display: flex; justify-content: flex-end; gap: 8px;">
                                    <button @onclick="() => AbrirModalDetalle(proforma)" style="background: rgba(59, 130, 246, 0.1); color: #3B82F6; border: none; padding: 6px 10px; border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: 600;"><i class="bi bi-eye-fill"></i> Ver</button>
                                    @if (!proforma.anulada && proforma.estadoSunat != "CONVERTIDA")
                                    {
                                        <button @onclick="() => ConvertirVenta(proforma)" style="background: rgba(16, 185, 129, 0.1); color: #10B981; border: none; padding: 6px 10px; border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: 600;"><i class="bi bi-cart-check-fill"></i> Convertir</button>
                                        <button @onclick="() => AbrirModalAnular(proforma)" style="background: rgba(239, 68, 68, 0.1); color: #EF4444; border: none; padding: 6px 10px; border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: 600;"><i class="bi bi-x-circle-fill"></i> Anular</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- Estilos base para modales nativos -->
<style>
    .modal-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(15, 23, 42, 0.6);
        display: flex; align-items: center; justify-content: center;
        z-index: 1000;
        backdrop-filter: blur(4px);
    }
    .modal-content {
        background: #FFFFFF;
        border-radius: 16px;
        padding: 24px;
        width: 100%;
        max-width: 500px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        max-height: 90vh;
        overflow-y: auto;
    }
    .modal-content.large {
        max-width: 800px;
    }
    .detail-row {
        display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px dashed #E2E8F0;
    }
    .detail-label {
        color: #6B7280; font-size: 14px; font-weight: 500;
    }
    .detail-value {
        color: #111827; font-size: 14px; font-weight: 600;
    }
</style>

<!-- Modal Detalle -->
@if (mostrarModalDetalle && proformaSeleccionada != null)
{
    <div class="modal-overlay" @onclick="CerrarModalDetalle">
        <div class="modal-content large" @onclick:stopPropagation>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h5 style="margin: 0; font-size: 18px; font-weight: 700; color: #111827;">Resumen de Proforma</h5>
                <button @onclick="CerrarModalDetalle" style="background: none; border: none; font-size: 20px; color: #94A3B8; cursor: pointer;"><i class="bi bi-x-lg"></i></button>
            </div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;">
                <div>
                    <div class="detail-row"><span class="detail-label">ID</span><span class="detail-value">@proformaSeleccionada.numeroComprobante</span></div>
                    <div class="detail-row"><span class="detail-label">Cliente</span><span class="detail-value">@proformaSeleccionada.cliente</span></div>
                    <div class="detail-row" style="border-bottom: none;"><span class="detail-label">Fecha</span><span class="detail-value">@proformaSeleccionada.fechaHora.ToString("dd/MM/yyyy HH:mm")</span></div>
                </div>
                <div>
                    <div class="detail-row"><span class="detail-label">Estado</span><span class="detail-value">@proformaSeleccionada.tipoComprobante</span></div>
                    <div class="detail-row"><span class="detail-label">Total</span><span class="detail-value" style="color: #10B981;">@simboloMoneda @proformaSeleccionada.total.ToString("N2")</span></div>
                    <div class="detail-row" style="border-bottom: none;"><span class="detail-label">Registrado por</span><span class="detail-value">@proformaSeleccionada.nombreUsuario</span></div>
                </div>
            </div>

            <h6 style="font-weight: 700; margin: 0 0 12px 0; font-size: 15px; color: #374151;">Productos</h6>
            <div style="overflow-x: auto; margin-bottom: 16px; border: 1px solid #E2E8F0; border-radius: 8px;">
                <table style="width: 100%; border-collapse: collapse;">
                    <thead style="background: #F8FAFC;">
                        <tr>
                            <th style="text-align: left; font-weight: 600; color: #6B7280; font-size: 12px; padding: 10px 12px; border-bottom: 1px solid #E2E8F0;">PRODUCTO</th>
                            <th style="text-align: center; font-weight: 600; color: #6B7280; font-size: 12px; padding: 10px 12px; border-bottom: 1px solid #E2E8F0;">CANT.</th>
                            <th style="text-align: right; font-weight: 600; color: #6B7280; font-size: 12px; padding: 10px 12px; border-bottom: 1px solid #E2E8F0;">UNIT.</th>
                            <th style="text-align: right; font-weight: 600; color: #6B7280; font-size: 12px; padding: 10px 12px; border-bottom: 1px solid #E2E8F0;">SUBTOTAL</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if(proformaSeleccionada.items != null)
                        {
                            @foreach (var item in proformaSeleccionada.items)
                            {
                                <tr>
                                    <td style="padding: 10px 12px; border-bottom: 1px solid #F1F5F9; font-size: 13px;">@item.nombreProducto</td>
                                    <td style="text-align: center; padding: 10px 12px; border-bottom: 1px solid #F1F5F9; font-size: 13px;">@item.cantidad</td>
                                    <td style="text-align: right; padding: 10px 12px; border-bottom: 1px solid #F1F5F9; font-size: 13px;">@simboloMoneda @item.precioUnitario.ToString("N2")</td>
                                    <td style="text-align: right; padding: 10px 12px; border-bottom: 1px solid #F1F5F9; font-size: 13px; font-weight: 600;">@simboloMoneda @item.subtotal.ToString("N2")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div style="display: flex; justify-content: flex-end; align-items: center; padding-top: 16px;">
                <h5 style="margin: 0; font-weight: 800; color: #10B981; font-size: 20px;">Total: @simboloMoneda @proformaSeleccionada.total.ToString("N2")</h5>
            </div>
            
            <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 24px;">
                <button @onclick="@(() => ImprimirPDF(proformaSeleccionada))" style="background: white; border: 1px solid #E2E8F0; padding: 10px 16px; border-radius: 8px; font-weight: 600; color: #475569; cursor: pointer; display: flex; align-items: center; gap: 8px;"><i class="bi bi-file-earmark-pdf-fill"></i> Imprimir PDF</button>
                @if (!proformaSeleccionada.anulada && proformaSeleccionada.estadoSunat != "CONVERTIDA")
                {
                    <button @onclick="@(() => ConvertirVenta(proformaSeleccionada))" style="background: #10B981; border: none; padding: 10px 16px; border-radius: 8px; font-weight: 600; color: white; cursor: pointer;"><i class="bi bi-cart-check-fill"></i> Convertir a Venta</button>
                }
                <button @onclick="CerrarModalDetalle" style="background: #4F46E5; border: none; padding: 10px 16px; border-radius: 8px; font-weight: 600; color: white; cursor: pointer;">Cerrar</button>
            </div>
        </div>
    </div>
}

<!-- Modal Anular -->
@if (mostrarModalAnular && proformaSeleccionada != null)
{
    <div class="modal-overlay" @onclick="CerrarModalAnular">
        <div class="modal-content" @onclick:stopPropagation style="text-align: center; max-width: 400px;">
            <div style="width: 64px; height: 64px; border-radius: 50%; background: rgba(239, 68, 68, 0.1); color: #EF4444; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px auto; font-size: 32px;">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <h5 style="margin: 0 0 8px 0; font-size: 18px; font-weight: 700; color: #111827;">¿Anular Proforma?</h5>
            <p style="margin: 0; color: #111827; font-weight: 600;">Proforma: @proformaSeleccionada.numeroComprobante</p>
            <p style="margin: 8px 0 24px 0; color: #6B7280; line-height: 1.5; font-size: 14px;">Confirmas que deseas anular esta proforma. Esta acción no se puede deshacer.</p>
            
            <div style="display: flex; justify-content: center; gap: 12px;">
                <button @onclick="CerrarModalAnular" style="background: white; border: 1px solid #E2E8F0; padding: 10px 16px; border-radius: 8px; font-weight: 600; color: #475569; cursor: pointer;">Cancelar</button>
                <button @onclick="ConfirmarAnulacion" style="background: #EF4444; border: none; padding: 10px 16px; border-radius: 8px; font-weight: 600; color: white; cursor: pointer;">Confirmar</button>
            </div>
        </div>
    </div>
}

@code {
    private List<VentaModel> proformas = new();
    private List<VentaModel> proformasFiltradas = new();
    private VentaModel? proformaSeleccionada = null;

    private DateTime fechaInicio = DateTime.Today.AddDays(-30);
    private DateTime fechaFin = DateTime.Today;
    private string textoBusqueda = string.Empty;
    private string estadoFiltro = string.Empty;

    private bool cargando = true;
    private bool mostrarModalDetalle = false;
    private bool mostrarModalAnular = false;
    private string simboloMoneda = "S/";

    protected override async Task OnInitializedAsync()
    {
        StateService.OnChange += StateHasChanged;
        await CargarConfiguracion();
        await CargarProformas();
    }

    public void Dispose() => StateService.OnChange -= StateHasChanged;

    private async Task CargarConfiguracion()
    {
        var config = await ConfiguracionService.ObtenerConfiguracion();
        if (config != null) simboloMoneda = config.simboloMoneda;
    }

    private async Task CargarProformas()
    {
        try
        {
            cargando = true;
            var lista = await ProformasService.ObtenerProformasPorRango(fechaInicio, fechaFin);
            proformas = lista.ToList();
            FiltrarProformas();
        }
        catch { await NotificationService.ShowError("Error al cargar proformas"); }
        finally { cargando = false; }
    }

    private void FiltrarProformas()
    {
        var query = proformas.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(textoBusqueda))
        {
            var term = textoBusqueda.ToLower().Trim();
            query = query.Where(p => (p.cliente != null && p.cliente.ToLower().Contains(term)) || (p.numeroComprobante != null && p.numeroComprobante.ToLower().Contains(term)));
        }

        if (!string.IsNullOrWhiteSpace(estadoFiltro))
        {
            switch (estadoFiltro)
            {
                case "pendiente": query = query.Where(p => !p.anulada && p.estadoSunat != "CONVERTIDA"); break;
                case "convertida": query = query.Where(p => p.estadoSunat == "CONVERTIDA"); break;
                case "anulada": query = query.Where(p => p.anulada); break;
            }
        }

        proformasFiltradas = query.ToList();
    }

    private void AbrirModalDetalle(VentaModel p) { proformaSeleccionada = p; mostrarModalDetalle = true; }
    private void CerrarModalDetalle() { mostrarModalDetalle = false; proformaSeleccionada = null; }

    private void AbrirModalAnular(VentaModel p) { proformaSeleccionada = p; mostrarModalAnular = true; }
    private void CerrarModalAnular() { mostrarModalAnular = false; proformaSeleccionada = null; }

    private async Task ConfirmarAnulacion()
    {
        if (proformaSeleccionada == null) return;
        var id = proformaSeleccionada.id;
        CerrarModalAnular();

        try
        {
            var res = await ProformasService.EliminarProforma(id);
            if (res) { await NotificationService.ShowSuccess("Proforma anulada correctamente"); await CargarProformas(); }
            else { await NotificationService.ShowError("No se pudo anular la proforma"); }
        }
        catch { await NotificationService.ShowError("Error en la operación"); }
    }

    private async Task ConvertirVenta(VentaModel p)
    {
        try
        {
            var res = await ProformasService.ConvertirAVenta(p.id);
            if (res) { await NotificationService.ShowSuccess("Proforma convertida a venta con éxito"); CerrarModalDetalle(); await CargarProformas(); }
            else { await NotificationService.ShowError("Error al convertir proforma"); }
        }
        catch { await NotificationService.ShowError("Error crítico de conversión"); }
    }

    private async Task ImprimirPDF(VentaModel p)
    {
        await JSRuntime.InvokeVoidAsync("open", $"/api/impresion/Proforma/{p.id}/pdf", "_blank");
    }
}
