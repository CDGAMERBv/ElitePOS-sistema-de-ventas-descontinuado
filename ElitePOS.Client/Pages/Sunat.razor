@page "/sunat"
@using ElitePOS.Shared.Models
@using ElitePOS.Client.Services
@using Microsoft.AspNetCore.Components.Forms
@inject IConfiguracionSunatService SunatService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<style>
    /* 챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍 BOT챦쩔쩍"N PREMIUM 챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍챦쩔쩍.챦쩔쩍 */
    .btn-guardar-premium {
        padding: 12px 28px;
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: 700;
        font-size: 15px;
