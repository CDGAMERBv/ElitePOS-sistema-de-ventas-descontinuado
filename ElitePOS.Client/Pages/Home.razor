@page "/home"
@using ElitePOS.Shared.Models
@using ElitePOS.Client.Services
@inject IDashboardStateService DashboardService
@inject IConfiguracionEmpresaService ConfiguracionService
@inject ISesionService SesionService
@inject NavigationManager Navigation
@implements IDisposable

<div class="dashboard-premium px-4 py-6" style="padding: 24px;">
    <!-- Page Header -->
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 24px; flex-wrap: wrap; gap: 16px;">
        <div>
            <h4 style="font-weight: 800; font-size: 24px; margin: 0 0 8px 0; color: #111827;">Panel de Control</h4>
            <p style="margin: 0; color: #6B7280; font-size: 14px;">
                Bienvenido de vuelta, <strong style="color: #111827;">@(SesionService.UsuarioActual?.nombre ?? "Usuario")</strong>
                <span style="background-color: #4F46E5; color: white; margin-left: 8px; border-radius: 6px; padding: 2px 8px; font-size: 12px; font-weight: 600;">
                    @(SesionService.UsuarioActual?.rol ?? "Rol")
                </span>
            </p>
        </div>
        <div>
            <p style="margin: 0; color: #6B7280; font-size: 14px; display: flex; align-items: center; gap: 8px;">
                <i class="bi bi-calendar-today"></i>
                Hoy: @DateTime.Now.ToString("dd 'de' MMMM, yyyy")
            </p>
        </div>
    </div>

    <!-- KPI Cards Row -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 24px;">
        <div class="glass-card" style="padding: 20px; display: flex; align-items: center; justify-content: space-between;">
            <div>
                <span style="color: #6B7280; font-size: 12px; font-weight: 600; text-transform: uppercase;">Ventas Hoy</span>
                <h4 style="font-weight: 800; margin: 8px 0; font-size: 24px; color: #111827;">S/ @DashboardService.VentasHoy.ToString("N2")</h4>
                <span style="font-size: 12px; color: #10B981; font-weight: 500;">@DashboardService.TransaccionesHoy transacciones</span>
            </div>
            <div style="background: rgba(16, 185, 129, 0.1); color: #10B981; width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-graph-up-arrow fs-5"></i>
            </div>
        </div>

        <div class="glass-card" style="padding: 20px; display: flex; align-items: center; justify-content: space-between;">
            <div>
                <span style="color: #6B7280; font-size: 12px; font-weight: 600; text-transform: uppercase;">Ventas Semana</span>
                <h4 style="font-weight: 800; margin: 8px 0; font-size: 24px; color: #111827;">S/ @DashboardService.VentasSemana.ToString("N2")</h4>
                <span style="font-size: 12px; color: #6B7280; font-weight: 500;">Rendimiento acumulado</span>
            </div>
            <div style="background: rgba(79, 70, 229, 0.1); color: #4F46E5; width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-calendar-date fs-5"></i>
            </div>
        </div>

        <div class="glass-card" style="padding: 20px; display: flex; align-items: center; justify-content: space-between;">
            <div>
                <span style="color: #6B7280; font-size: 12px; font-weight: 600; text-transform: uppercase;">Clientes</span>
                <h4 style="font-weight: 800; margin: 8px 0; font-size: 24px; color: #111827;">@DashboardService.TotalClientes</h4>
                <span style="font-size: 12px; color: #6B7280; font-weight: 500;">Clientes registrados</span>
            </div>
            <div style="background: rgba(59, 130, 246, 0.1); color: #3B82F6; width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-people fs-5"></i>
            </div>
        </div>

        <div class="glass-card" style="padding: 20px; display: flex; align-items: center; justify-content: space-between;">
            <div>
                <span style="color: #6B7280; font-size: 12px; font-weight: 600; text-transform: uppercase;">Stock Crítico</span>
                <h4 style="font-weight: 800; margin: 8px 0; font-size: 24px; color: #111827;">@DashboardService.StockBajoCount</h4>
                <span style="font-size: 12px; color: #EF4444; font-weight: 500;">Productos en alerta</span>
            </div>
            <div style="background: rgba(239, 68, 68, 0.1); color: #EF4444; width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-exclamation-triangle fs-5"></i>
            </div>
        </div>
    </div>

    <!-- Chart Section & Alertas Row -->
    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 24px;">
        <div class="glass-card" style="padding: 24px;">
            <div style="margin-bottom: 24px;">
                <h5 style="font-weight: 700; margin: 0 0 4px 0; font-size: 16px; color: #111827;">Tendencia de Ventas (Mensual)</h5>
                <p style="margin: 0; color: #6B7280; font-size: 13px;">Evolución de facturación mensual del negocio</p>
            </div>
            <div>
                @if (DashboardService.DatosCargados && MesesLabels.Length > 0)
                {
                    <div style="height: 300px; display: flex; align-items: flex-end; gap: 12px;">
                        @{
                            var maxVenta = SeriesVentas.FirstOrDefault()?.Data.Max() ?? 1;
                            if (maxVenta == 0) maxVenta = 1;
                            var i = 0;
                        }
                        @foreach (var val in SeriesVentas.FirstOrDefault()?.Data ?? Array.Empty<double>())
                        {
                            var pct = (val / maxVenta) * 100;
                            var mesLabel = MesesLabels.ElementAtOrDefault(i) ?? "";
                            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; height: 100%;">
                                <div style="width: 100%; background: #4F46E5; border-radius: 4px 4px 0 0; height: @(pct)%; min-height: 5px; opacity: 0.85;"></div>
                                <span style="font-size: 12px; color: #6B7280; margin-top: 12px; font-weight: 500;">@mesLabel</span>
                            </div>
                            i++;
                        }
                    </div>
                }
                else
                {
                    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 300px;">
                        <p style="color: #6B7280; font-size: 14px;">Cargando tendencia de ventas...</p>
                    </div>
                }
            </div>
        </div>

        <div class="glass-card" style="padding: 24px;">
            <div style="margin-bottom: 24px;">
                <h5 style="font-weight: 700; margin: 0 0 4px 0; font-size: 16px; color: #111827;">Productos Más Vendidos</h5>
                <p style="margin: 0; color: #6B7280; font-size: 13px;">Distribución de ingresos por producto</p>
            </div>
            <div style="display: flex; flex-direction: column; align-items: center;">
                @if (TopProductosData != null && TopProductosLabels != null && TopProductosData.Length > 0 && TopProductosData.Length == TopProductosLabels.Length)
                {
                    <div style="width: 100%; max-height: 300px; overflow-y: auto;">
                        @for (int i = 0; i < TopProductosData.Length; i++)
                        {
                            var labelSeguro = TopProductosLabels.ElementAtOrDefault(i) ?? "Producto";
                            var dataSegura = TopProductosData.ElementAtOrDefault(i);
                            <div style="display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; margin-bottom: 8px; background: #F8FAFC; border-radius: 8px; border: 1px solid #E2E8F0;">
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <div style="background-color: #4F46E5; width: 8px; height: 8px; border-radius: 50%;"></div>
                                    <span style="font-size: 13px; font-weight: 500; color: #111827;">@labelSeguro</span>
                                </div>
                                <span style="font-weight: 700; font-size: 13px; color: #111827;">S/ @dataSegura.ToString("N2")</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 300px; width: 100%;">
                        <i class="bi bi-pie-chart text-muted mb-3" style="font-size: 32px; color: #94A3B8;"></i>
                        <p style="color: #6B7280; font-size: 14px;">No hay datos suficientes.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Stock Alerts Section -->
    <div class="glass-card" style="padding: 24px;">
        <div style="margin-bottom: 24px;">
            <div style="display: flex; align-items: center; gap: 8px;">
                <i class="bi bi-exclamation-triangle" style="color: #F59E0B; font-size: 20px;"></i>
                <h5 style="font-weight: 700; margin: 0; font-size: 16px; color: #111827;">Alerta de Inventario Crítico</h5>
            </div>
            <p style="margin: 4px 0 0 0; color: #6B7280; font-size: 13px;">Productos que requieren reposición inmediata</p>
        </div>
        <div>
            @if (DashboardService.ProductosBajoStock.Any())
            {
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr>
                                <th style="text-align: left; font-weight: 600; color: #6B7280; font-size: 12px; padding-bottom: 16px; border-bottom: 1px solid #E2E8F0;">PRODUCTO</th>
                                <th style="text-align: center; font-weight: 600; color: #6B7280; font-size: 12px; padding-bottom: 16px; border-bottom: 1px solid #E2E8F0;">STOCK ACTUAL</th>
                                <th style="text-align: right; font-weight: 600; color: #6B7280; font-size: 12px; padding-bottom: 16px; border-bottom: 1px solid #E2E8F0;">ESTADO</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var producto in DashboardService.ProductosBajoStock)
                            {
                                <tr>
                                    <td style="padding: 16px 0; border-bottom: 1px solid #F1F5F9;">
                                        <div style="display: flex; align-items: center; gap: 12px;">
                                            <div style="width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #EF4444; background: rgba(239,68,68,0.1);">
                                                <i class="bi bi-box-seam"></i>
                                            </div>
                                            <span style="font-weight: 500; color: #111827; font-size: 14px;">@producto.nombre</span>
                                        </div>
                                    </td>
                                    <td style="text-align: center; font-weight: 700; color: #EF4444; padding: 16px 0; border-bottom: 1px solid #F1F5F9; font-size: 14px;">
                                        @producto.stock
                                    </td>
                                    <td style="text-align: right; padding: 16px 0; border-bottom: 1px solid #F1F5F9;">
                                        <span style="background-color: rgba(239,68,68,0.1); color: #EF4444; padding: 4px 10px; border-radius: 6px; font-weight: 700; font-size: 11px; letter-spacing: 0.5px;">
                                            CRÍTICO
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 0;">
                    <i class="bi bi-check-circle" style="color: #10B981; font-size: 40px; margin-bottom: 12px;"></i>
                    <h6 style="color: #10B981; font-weight: 600; margin: 0 0 4px 0; font-size: 16px;">Todo el inventario OK</h6>
                    <p style="margin: 0; color: #6B7280; font-size: 13px;">No hay productos por debajo del stock mínimo</p>
                </div>
            }
        </div>
    </div>
</div>

@code {
    public class SimpleChartSeries
    {
        public string Name { get; set; } = string.Empty;
        public double[] Data { get; set; } = Array.Empty<double>();
    }

    // --- VARIABLES DE GRÁFICOS ---
    private string[] MesesLabels = { };
    private List<SimpleChartSeries> SeriesVentas = new();
    private double[] TopProductosData = { };
    private string[] TopProductosLabels = { };

    protected override async Task OnInitializedAsync()
    {
        // 🔒 Verificar Autenticación
        if (SesionService.UsuarioActual?.estaAutenticado != true)
        {
            Navigation.NavigateTo("/");
            return;
        }

        // 📈 Suscribirse a cambios del Dashboard
        DashboardService.OnChange += RecargarUI;

        // 🚀 Cargar datos reales de Firestore
        await DashboardService.CargarDatosAsync();
        
        // Mapear datos a gráficos después de la carga inicial
        ActualizarDatosGraficos();
    }

    private void RecargarUI()
    {
        ActualizarDatosGraficos();
        InvokeAsync(StateHasChanged);
    }

    private void ActualizarDatosGraficos()
    {
        if (DashboardService.DatosCargados)
        {
            // Mapeo para Gráfico de Líneas
            MesesLabels = DashboardService.VentasMensuales.Select(v => v.Mes).ToArray();
            SeriesVentas = new List<SimpleChartSeries> 
            { 
                new SimpleChartSeries 
                { 
                    Name = "Ventas", 
                    Data = DashboardService.VentasMensuales.Select(v => (double)v.Total).ToArray() 
                } 
            };

            // Mapeo para Gráfico de Dona (Snapshot Seguro)
            var snapshotProductos = DashboardService.ProductosMasVendidos?.ToList() ?? new();
            
            var tempLabels = snapshotProductos.Select(p => p.Nombre).ToArray();
            var tempData = snapshotProductos.Select(p => (double)p.Total).ToArray();

            int minLength = Math.Min(tempLabels.Length, tempData.Length);
            
            // Inyección Atómica Final
            TopProductosLabels = tempLabels.Take(minLength).ToArray();
            TopProductosData = tempData.Take(minLength).ToArray();
            
            InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        DashboardService.OnChange -= RecargarUI;
    }
}