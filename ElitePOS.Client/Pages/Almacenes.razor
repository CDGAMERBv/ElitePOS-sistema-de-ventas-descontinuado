    private void ConfirmarEliminar(string id, string nombre)
    {
        idAlmacenAEliminar = id;
        nombreAlmacenAEliminar = nombre;
        mostrarModalConfirmacion = true;
    }

    private void CancelarEliminar()
    {
        mostrarModalConfirmacion = false;
        idAlmacenAEliminar = string.Empty;
        nombreAlmacenAEliminar = string.Empty;
    }

    private async Task EjecutarEliminar()
    {
        var almacen = configuracion.almacenes.FirstOrDefault(a => a.nombre== idAlmacenAEliminar);
        mostrarModalConfirmacion = false;
        idAlmacenAEliminar = string.Empty;
        nombreAlmacenAEliminar = string.Empty;

        if (almacen == null) return;

        try
        {
            configuracion.almacenes.Remove(almacen);
            var success = await AlmacenesService.GuardarConfiguracion(configuracion);
            if (!success)
            {
                configuracion.almacenes.Add(almacen); // rollback
                await NotificationService.ShowError("No se pudo eliminar el almacﾃｩn.");
            }
            else
            {
                await NotificationService.ShowSuccess("Almacﾃｩn eliminado correctamente.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al eliminar almacﾃｩn: {ex.Message}");
            await NotificationService.ShowError("Error inesperado al eliminar.");
        }

    }

    private void Volver() => Navigation.NavigateTo("/configuracion");
}

