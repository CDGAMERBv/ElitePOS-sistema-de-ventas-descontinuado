    private void AbrirModalNuevo()
    {
        almacenActual = new AlmacenModel { activo = true };
        esEdicion = false;
        mostrarFormulario = true;
    }

    private void AbrirModalEditar(AlmacenModel almacen)
    {
        almacenActual = new AlmacenModel
        {
            id = almacen.id,
            empresaId = almacen.empresaId,
            codigo = almacen.codigo,
            nombre = almacen.nombre,
            ubicacion = almacen.ubicacion,
            activo = almacen.activo
        };
        esEdicion = true;
        mostrarFormulario = true;
    }

    private async Task GuardarAlmacen()
    {
        if (guardandoAlmacen) return;

        if (string.IsNullOrWhiteSpace(almacenActual.nombre))
        {
            await NotificationService.ShowWarning("El nombre del almacﾃｩn es obligatorio.");
            return;
        }

        try
        {
            guardandoAlmacen = true;
            StateHasChanged();

            if (esEdicion)
            {
                var existente = configuracion.almacenes.FirstOrDefault(a => a.id == almacenActual.id);
                if (existente != null)
                {
                    existente.codigo = almacenActual.codigo;
                    existente.nombre= almacenActual.nombre;
                    existente.ubicacion = almacenActual.ubicacion;
                    existente.activo = almacenActual.activo;
                }
            }
            else
            {
                almacenActual.nombre= Guid.NewGuid().ToString();
                configuracion.almacenes.Add(almacenActual);
            }

            var success = await AlmacenesService.GuardarConfiguracion(configuracion);

            if (success)
            {
                CerrarFormulario();
                await NotificationService.ShowSuccess("Almacﾃｩn guardado correctamente.");
            }
            else
            {
                await NotificationService.ShowError("No se pudo guardar el almacﾃｩn.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al guardar almacﾃｩn: {ex.Message}");
            await NotificationService.ShowError("Error inesperado al guardar.");
        }

        finally
        {
            guardandoAlmacen = false;
        }
    }

    private void CerrarFormulario()
    {
        mostrarFormulario = false;
        esEdicion = false;
        almacenActual = new AlmacenModel();
    }

