    private async Task GuardarConfiguracionSilencioso()
    {
        try
        {
            var success = await AlmacenesService.GuardarConfiguracion(configuracion);
            if (success)
            {
                mostrarToast = true;
                StateHasChanged();
                await Task.Delay(2500); // Ocultar toast despuﾃｩs de 2.5s
                mostrarToast = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error auto-guardado: {ex.Message}");
        }
    }

