    .section-card {
        background: white;
        border-radius: 16px;
        padding: 28px 32px;
        margin-bottom: 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.04);
        border: 1px solid #e5e7eb;
    }

    .section-title {
        font-size: 17px;
        font-weight: 700;
        color: #111827;
        margin: 0 0 20px 0;
        padding-bottom: 16px;
        border-bottom: 2px solid #f3f4f6;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-title.no-border {
        border-bottom: none;
        padding-bottom: 0;
        margin-bottom: 0;
    }

    .section-title i {
        color: #6366f1;
        font-size: 18px;
    }

    .badge-count {
        background: #e0e7ff;
        color: #4f46e5;
        font-size: 12px;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 12px;
    }

    .section-footer {
        margin-top: 24px;
        padding-top: 20px;
        border-top: 1px solid #f3f4f6;
        display: flex;
        justify-content: flex-end;
    }

