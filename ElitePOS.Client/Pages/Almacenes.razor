            {
                <div class="empty-state">
                    <i class="bi bi-building empty-icon-bi"></i>
                    <p class="empty-title">Sin almacenes registrados</p>
                    <p class="empty-subtitle">Agrega tu primer almacﾃｩn o punto de distribuciﾃｳn</p>
                </div>
            }
            else
            {
                <table class="almacenes-table">
                    <thead>
                        <tr>
                            <th>Cﾃｳdigo</th>
                            <th>Nombre del Almacﾃｩn</th>
                            <th>Direcciﾃｳn</th>
                            <th class="th-center">Estado</th>
                            <th class="th-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var almacen in configuracion.almacenes)
                        {
                            <tr class="almacen-row">
                                <td class="td-codigo">@(string.IsNullOrEmpty(almacen.codigo) ? "-" : almacen.codigo)</td>
                                <td class="td-nombre">@almacen.nombre</td>
                                <td class="td-ubicacion">@(string.IsNullOrEmpty(almacen.ubicacion) ? "-" : almacen.ubicacion)</td>
                                <td class="td-center">
                                    <span class="badge-estado @(almacen.activo ? "badge-activo" : "badge-inactivo")">
                                        @(almacen.activo ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td class="td-center">
                                    <div class="action-buttons">
                                        <button @onclick="() => AbrirModalEditar(almacen)" class="btn-action btn-edit">
                                            <i class="bi bi-pencil"></i>
                                            Editar
                                        </button>
                                        <button @onclick="() => ConfirmarEliminar(almacen.nombre, almacen.nombre)" class="btn-action btn-delete">
                                            <i class="bi bi-trash"></i>
                                            Eliminar
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
